{
  "_source": "~/w/agentscode/opencode/packages/tui/src/theme/assets/opencode.json (dark variant) + theme/index.ts",
  "_note": "opencode TUI 默认主题 = opencode dark;全字面 hex(sRGB),非 ANSI 索引。渲染引擎 = @opentui(终端 cell buffer)。字体 = 终端等宽(1 cell = 1 char),无 font-size/line-height 配置。",
  "scheme": "dark",
  "base": {
    "background": "#0a0a0a",
    "backgroundPanel": "#141414",
    "backgroundElement": "#1e1e1e",
    "text": "#eeeeee",
    "textMuted": "#808080",
    "primary": "#fab283",
    "secondary": "#5c9cf5",
    "accent": "#9d7cd8",
    "error": "#e06c75",
    "warning": "#f5a742",
    "success": "#7fd88f",
    "info": "#56b6c2",
    "border": "#484848",
    "borderActive": "#606060",
    "borderSubtle": "#3c3c3c"
  },
  "markdown": {
    "text": "#eeeeee",
    "heading": "#9d7cd8",
    "headingBold": true,
    "h1Underline": true,
    "strong": "#f5a742",
    "emph": "#e5c07b",
    "codeInline": "#7fd88f",
    "codeInlineBg": "#0a0a0a",
    "blockQuote": "#e5c07b",
    "link": "#fab283",
    "linkText": "#56b6c2",
    "listItem": "#fab283",
    "listEnumeration": "#56b6c2",
    "horizontalRule": "#808080",
    "strikethrough": "#808080"
  },
  "diff": {
    "added": "#4fd6be",
    "removed": "#c53b53",
    "addedBg": "#20303b",
    "removedBg": "#37222c",
    "highlightAdded": "#b8db87",
    "highlightRemoved": "#e26a75",
    "context": "#828bb8",
    "contextBg": "#141414",
    "lineNumber": "#8f8f8f",
    "addedLineNumberBg": "#1b2b34",
    "removedLineNumberBg": "#2d1f26"
  },
  "syntax": {
    "comment": "#808080",
    "keyword": "#9d7cd8",
    "function": "#fab283",
    "variable": "#e06c75",
    "string": "#7fd88f",
    "number": "#f5a742",
    "type": "#e5c07b",
    "operator": "#56b6c2",
    "punctuation": "#eeeeee"
  },
  "layout": {
    "assistantIndentCells": 3,
    "cardLeftPadCells": 2,
    "interElementGapLines": 1,
    "cardBorderChar": "┃",
    "cardBorderVocabulary": "仅左侧重竖线 ┃(SplitBorder);无 ┌─┐└┘ 角、无圆角、无整框。表格/ diff 内部才有 box-drawing 网格。compaction = 顶边 rule。",
    "userCardFill": "backgroundPanel",
    "assistantProseFill": "none",
    "monospace": true,
    "cellIsOneChar": true
  },
  "agentAccentRotation": ["#5c9cf5", "#9d7cd8", "#7fd88f", "#f5a742", "#fab283", "#e06c75", "#56b6c2"],
  "reasoningOpacity": 0.6
}
