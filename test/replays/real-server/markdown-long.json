变量失效 |\\n\\n```rust\\nfn main() {\\n    let s1 = String::from(\\\"hello\\\");\\n    let s2 = s1; // s1 的所有权移动到 s2\\n    // println!(\\\"{s1}\\\"); // ✗ 编译错误：s1 已失效\\n    println!(\\\"{s2}\\\");    // ✓ 正常输出 hello\\n}\\n```\\n\\n- 所有权机制让 Rust 在**编译期**消除数据竞争与悬垂指针\\n- 借用（`&` / `&mut`）让值在不转移所有权的情况下被引用\\n- `Clone` trait 可显式深拷贝，绕过移动语义\\n\\n更多细节见官方文档：[The Rust Programming Language](https://doc.rust-lang.org)。\",\"time\":{\"start\":1783963431469,\"end\":1783963435586}},\"time\":1783963435586}}"},{"t":13249,"raw":"{\"id\":\"evt_f5c81c298001gughWOi3HKUKe4\",\"type\":\"message.part.updated\",\"properties\":{\"sessionID\":\"ses_0a37e70f2ffeXEDOrdkwOxRRMk\",\"part\":{\"id\":\"prt_f5c81c297001R6OQwrhKtudXsT\",\"reason\":\"stop\",\"snapshot\":\"172c08438067e5edab23204db75e0b78a2e840d7\",\"messageID\":\"msg_f5c818f26001VHAABegNu8y6AB\",\"sessionID\":\"ses_0a37e70f2ffeXEDOrdkwOxRRMk\",\"type\":\"step-finish\",\"tokens\":{\"total\":13982,\"input\":13604,\"output\":233,\"reasoning\":145,\"cache\":{\"write\":0,\"read\":0}},\"cost\":0},\"time\":1783963435671}}"},{"t":13249,"raw":"{\"id\":\"evt_f5c81c29a001Fea1xV52c4qWIb\",\"type\":\"message.updated\",\"properties\":{\"sessionID\":\"ses_0a37e70f2ffeXEDOrdkwOxRRMk\",\"info\":{\"id\":\"msg_f5c818f26001VHAABegNu8y6AB\",\"parentID\":\"msg_f5c818f1a001TvkRJ5dCedLTiH\",\"role\":\"assistant\",\"mode\":\"build\",\"agent\":\"build\",\"path\":{\"cwd\":\"/Users/wp/w/wasm/opencode-chat\",\"root\":\"/Users/wp/w/wasm/opencode-chat\"},\"cost\":0,\"tokens\":{\"total\":13982,\"input\":13604,\"output\":233,\"reasoning\":145,\"cache\":{\"write\":0,\"read\":0}},\"modelID\":\"qwen3.7-max\",\"providerID\":\"aliyuntokenplan\",\"time\":{\"created\":1783963422502},\"sessionID\":\"ses_0a37e70f2ffeXEDOrdkwOxRRMk\",\"finish\":\"stop\"}}}"},{"t":13332,"raw":"{\"id\":\"evt_f5c81c2e70011zYEOk3CvzFaRt\",\"type\":\"message.updated\",\"properties\":{\"sessionID\":\"ses_0a37e70f2ffeXEDOrdkwOxRRMk\",\"info\":{\"id\":\"msg_f5c818f26001VHAABegNu8y6AB\",\"parentID\":\"msg_f5c